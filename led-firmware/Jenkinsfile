library identifier: 'shared_library@main', retriever: modernSCM(
    [$class: 'GitSCMSource',
     remote: 'https://github.com/sharan97-cyber/shared_library.git',
     traits: [[$class: 'CloneOptionTrait']]]
)

pipeline {
    agent { label 'linux-agent' }
    options {
        timestamps()
    }
    environment {
        BUILD_DIR = 'build'
        PROJECT_DIR = 'led-firmware'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Prepare') {
            steps {
                script {
                    echo 'Using shared library: prepareEnvironment()'
                    prepareEnvironment(env.PROJECT_DIR)
                }
            }
        }
        stage('Lint') {
            steps {
                script {
                    echo 'Using shared library: runClangFormat()'
                    runClangFormat(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        
        stage('Parallel Build Validation') {
            parallel {
                stage('Static Code Analysis') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            set -e
                            echo "========== Running Static Code Analysis =========="
                            mkdir -p "${BUILD_DIR}"
                            
                            if [ -f src/led.c ]; then
                                echo "Analyzing source code with strict compiler warnings..."
                                cc -std=c99 -Wall -Wextra -Wconversion -Wsign-conversion -Wunused -Iinclude -c src/led.c -o "${BUILD_DIR}/led.o" 2>&1 || true
                                echo "========== Static Analysis Complete =========="
                            else
                                echo "⚠️  Source files not found, skipping static analysis"
                            fi
                            '''
                        }
                    }
                }
                
                stage('Pre-Build Check') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            set -e
                            echo "========== Running Pre-Build Checks =========="
                            
                            # Check for required files
                            echo "Checking for required source files..."
                            if [ -f CMakeLists.txt ]; then
                                echo "✅ CMakeLists.txt found"
                            else
                                echo "⚠️  CMakeLists.txt not found"
                            fi
                            
                            if [ -f src/led.c ]; then
                                echo "✅ src/led.c found"
                            else
                                echo "⚠️  src/led.c not found"
                            fi
                            
                            if [ -f arm-gcc-toolchain.cmake ]; then
                                echo "✅ ARM GCC toolchain found"
                            else
                                echo "⚠️  ARM GCC toolchain not found"
                            fi
                            
                            # Check compiler versions
                            echo ""
                            echo "Compiler information:"
                            gcc --version | head -1
                            cmake --version | head -1
                            
                            echo "========== Pre-Build Checks Complete =========="
                            '''
                        }
                    }
                }
            }
        }
        
        stage('Unit Tests') {
            steps {
                dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                    sh '''
                    set -e
                    mkdir -p "${BUILD_DIR}"
                    echo "========== Running Unit Tests =========="
                    cc -std=c99 -Wall -Wextra -Iinclude tests/led_test.c src/led.c -o "${BUILD_DIR}/led_test"
                    "${BUILD_DIR}/led_test"
                    echo "========== Unit Tests Passed =========="
                    '''
                }
            }
        }
        stage('Configure') {
            steps {
                dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                    sh '''
                    set -e
                    mkdir -p "${BUILD_DIR}"
                    cd "${BUILD_DIR}"
                    cmake .. -DCMAKE_TOOLCHAIN_FILE=../arm-gcc-toolchain.cmake
                    '''
                }
            }
        }
        stage('Build') {
            steps {
                script {
                    echo 'Using shared library: buildFirmware()'
                    buildFirmware(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        stage('Verify Artifacts') {
            steps {
                sh 'ls -lh ${PROJECT_DIR}/${BUILD_DIR} || true'
            }
        }
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/*.elf,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.hex,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.bin,${env.PROJECT_DIR}/${env.BUILD_DIR}/clang-format-report.txt", allowEmptyArchive: true
            }
        }
    }
    post {
        always {
            node('linux-agent') {
                script {
                    echo 'Post-build: archiving clang-format report and printing summary'
                    try {
                        archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/clang-format-report.txt", allowEmptyArchive: true
                        sh 'echo "--- clang-format report (post) ---"; cat ${PROJECT_DIR}/${BUILD_DIR}/clang-format-report.txt || true'
                    } catch (Exception e) {
                        echo "⚠️  Post-build archiving failed: ${e.message}"
                    }
                }
            }
        }
        success {
            echo 'Build succeeded.'
        }
        failure {
            echo 'Build failed.'
        }
    }
}
