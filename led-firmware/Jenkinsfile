library identifier: 'shared_library@main', retriever: modernSCM(
    [$class: 'GitSCMSource',
     remote: 'https://github.com/sharan97-cyber/shared_library.git',
     traits: [[$class: 'CloneOptionTrait']]]
)

pipeline {
    agent { label 'linux-agent' }
    options {
        timestamps()
    }
    environment {
        BUILD_DIR = 'build'
        PROJECT_DIR = 'led-firmware'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Prepare & Lint') {
            steps {
                script {
                    echo 'Using shared library: prepareEnvironment()'
                    prepareEnvironment(env.PROJECT_DIR)
                    echo 'Using shared library: runClangFormat()'
                    runClangFormat(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        
        stage('Parallel Validation') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            mkdir -p "${BUILD_DIR}"
                            cc -std=c99 -Wall -Wextra -Iinclude tests/led_test.c src/led.c -o "${BUILD_DIR}/led_test"
                            "${BUILD_DIR}/led_test"
                            '''
                        }
                    }
                }
                
                stage('Static Analysis') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            mkdir -p "${BUILD_DIR}"
                            [ -f src/led.c ] && cc -std=c99 -Wall -Wextra -Wconversion -Wsign-conversion -Iinclude -c src/led.c -o "${BUILD_DIR}/led.o" 2>&1 || true
                            '''
                        }
                    }
                }
            }
        }
        
        stage('Build') {
            steps {
                dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                    sh '''
                    mkdir -p "${BUILD_DIR}"
                    cd "${BUILD_DIR}"
                    cmake .. -DCMAKE_TOOLCHAIN_FILE=../arm-gcc-toolchain.cmake
                    '''
                }
                script {
                    echo 'Using shared library: buildFirmware()'
                    buildFirmware(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/*.elf,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.hex,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.bin", allowEmptyArchive: true
            }
        }
    }
    post {
        always {
            node('linux-agent') {
                script {
                    try {
                        sh 'cat ${PROJECT_DIR}/${BUILD_DIR}/clang-format-report.txt 2>/dev/null || echo "No report"'
                    } catch (Exception e) {
                        echo "⚠️  Post-build: ${e.message}"
                    }
                }
            }
        }
        success {
            echo '✅ Build succeeded.'
        }
        failure {
            echo '❌ Build failed.'
        }
    }
}
