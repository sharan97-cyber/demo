library identifier: 'shared_library@main', retriever: modernSCM(
    [$class: 'GitSCMSource',
     remote: 'https://github.com/sharan97-cyber/shared_library.git',
     traits: [[$class: 'CloneOptionTrait']]]
)

pipeline {
    agent { label 'linux-agent' }
    
    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    
    environment {
        BUILD_DIR = 'build'
        PROJECT_DIR = 'led-firmware'
    }
    
    stages {
        stage('Checkout') {
            options {
                retry(2)  // ✅ Retry this stage if it fails
            }
            steps {
                checkout scm
                sh 'echo "✅ Checkout completed successfully"'
            }
        }
        
        stage('Prepare') {
            steps {
                script {
                    echo '========== Prepare Environment =========='
                    prepareEnvironment(env.PROJECT_DIR)
                }
            }
        }
        
        stage('Lint') {
            steps {
                script {
                    echo '========== Code Formatting Check =========='
                    runClangFormat(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        
        stage('Parallel Validation') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            set -e
                            mkdir -p "${BUILD_DIR}"
                            echo "========== Running Unit Tests =========="
                            if [ -f tests/led_test.c ] && [ -f src/led.c ]; then
                                cc -std=c99 -Wall -Wextra -Iinclude tests/led_test.c src/led.c -o "${BUILD_DIR}/led_test"
                                "${BUILD_DIR}/led_test"
                                echo "✅ Unit Tests Passed"
                            else
                                echo "⚠️  Test files not found, skipping unit tests"
                            fi
                            '''
                        }
                    }
                }
                
                stage('Static Analysis') {
                    steps {
                        dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                            sh '''
                            set -e
                            echo "========== Running Static Analysis =========="
                            mkdir -p "${BUILD_DIR}"
                            
                            if [ -f src/led.c ]; then
                                echo "Analyzing src/led.c with strict compiler warnings..."
                                cc -std=c99 -Wall -Wextra -Wconversion -Wsign-conversion -Wunused -Iinclude -c src/led.c -o "${BUILD_DIR}/led.o" 2>&1 || true
                                echo "✅ Static Analysis Complete"
                            else
                                echo "⚠️  Source files not found, skipping static analysis"
                            fi
                            '''
                        }
                    }
                }
            }
        }
        
        stage('Configure') {
            steps {
                dir("${env.WORKSPACE}/${env.PROJECT_DIR}") {
                    sh '''
                    set -e
                    echo "========== CMake Configuration =========="
                    mkdir -p "${BUILD_DIR}"
                    cd "${BUILD_DIR}"
                    if [ -f ../CMakeLists.txt ]; then
                        if [ -f ../arm-gcc-toolchain.cmake ]; then
                            echo "Using ARM GCC toolchain..."
                            cmake .. -DCMAKE_TOOLCHAIN_FILE=../arm-gcc-toolchain.cmake
                        else
                            echo "Using default toolchain..."
                            cmake ..
                        fi
                        echo "✅ CMake Configuration Complete"
                    else
                        echo "⚠️  CMakeLists.txt not found, skipping configure"
                    fi
                    '''
                }
            }
        }
        
        stage('Build') {
            steps {
                script {
                    echo '========== Building Firmware =========='
                    buildFirmware(env.PROJECT_DIR, env.BUILD_DIR)
                }
            }
        }
        
        stage('Verify Artifacts') {
            steps {
                sh '''
                echo "========== Verifying Build Artifacts =========="
                if [ -d ${PROJECT_DIR}/${BUILD_DIR} ]; then
                    ls -lh ${PROJECT_DIR}/${BUILD_DIR}
                    echo "✅ Build artifacts verified"
                else
                    echo "⚠️  Build directory not found"
                fi
                '''
            }
        }
    }
    
    post {
        always {
            node('linux-agent') {
                script {
                    echo '========== Post-Build: Archiving Artifacts =========='
                    try {
                        // Archive clang-format report
                        archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/clang-format-report.txt", 
                                       allowEmptyArchive: true
                        
                        // Archive firmware artifacts
                        archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/*.elf,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.hex,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.bin", 
                                       allowEmptyArchive: true
                        
                        // Print clang-format report if exists
                        sh '''
                        if [ -f ${PROJECT_DIR}/${BUILD_DIR}/clang-format-report.txt ]; then
                            echo "--- Clang Format Report ---"
                            cat ${PROJECT_DIR}/${BUILD_DIR}/clang-format-report.txt
                        else
                            echo "No clang-format report generated"
                        fi
                        '''
                        
                        echo '========== Post-Build: Archive Complete =========='
                    } catch (Exception e) {
                        echo "⚠️  Post-build archiving failed: ${e.message}"
                    }
                }
            }
        }
        success {
            echo '✅ BUILD SUCCEEDED - All stages completed successfully'
        }
        failure {
            echo '❌ BUILD FAILED - Check console output above for details'
        }
        unstable {
            echo '⚠️  BUILD UNSTABLE - Some warnings detected'
        }
    }
}
